# API Keys (no MARA_ prefix)
BRAVE_API_KEY=your_brave_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LangSmith tracing (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=mara

# MARA configuration (all optional — defaults shown)
MARA_MODEL=claude-sonnet-4-6
MARA_EMBEDDING_MODEL=all-MiniLM-L6-v2
MARA_MAX_SOURCES=30
MARA_MAX_WORKERS=3
MARA_MAX_CORRECTIVE_RAG_LOOPS=2
MARA_HIGH_CONFIDENCE_THRESHOLD=0.80
MARA_LOW_CONFIDENCE_THRESHOLD=0.55
MARA_SIMILARITY_SUPPORT_THRESHOLD=0.72
MARA_CONFIDENCE_WEIGHTS__ALPHA=0.4
MARA_CONFIDENCE_WEIGHTS__BETA=0.2
MARA_CONFIDENCE_WEIGHTS__GAMMA=0.4
MARA_HASH_ALGORITHM=sha256
MARA_CHUNK_SIZE=1000
MARA_CHUNK_OVERLAP=200
MARA_CHECKPOINTER=memory

# PostgreSQL (only required when MARA_CHECKPOINTER=postgres)
# MARA_POSTGRES_DSN=postgresql://user:password@localhost:5432/mara
